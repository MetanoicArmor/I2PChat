.cache/

# Release archives (host on GitHub Releases only; avoid >100MB)
I2PChat-macOS-arm64*.zip
I2PChat-windows*.zip
I2PChat-*.AppImage
I2PChat.AppImage
I2PChat.AppDir/
appimagetool-*.AppImage
I2PChat-linux-*.zip

# Per-build integrity artifacts (attach to GitHub Releases; do not commit — differs per OS/artifact)
SHA256SUMS
SHA256SUMS.asc

# Optional local bundled-router blobs for portable release builds only.
vendor/i2pd/

# Secrets / keys — never commit
*.dat
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*_rsa
*_ed25519
secrets.json
credentials.json
*.keystore
config.local.*

# Local agent / workflow artifacts (never push)
.omx/
.omc/

# IDE / editor (Cursor — не пушить)
.cursor/
docs/CURSOR_*.md
.idea/
*.log
*.swp
*.swo
*~

# Tests / coverage
.coverage
.coverage.*
htmlcov/

# Debian CI: copies of ../*.deb from dpkg-buildpackage (see docker-dpkg-buildpackage.yml)
