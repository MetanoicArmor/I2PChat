tar-ignore = ".cache"
tar-ignore = ".cursor"
tar-ignore = ".omx"
tar-ignore = ".omc"
tar-ignore = ".pybuild"
tar-ignore = ".venv"
tar-ignore = ".venv*"
tar-ignore = "I2PChat.AppDir"
tar-ignore = "I2PChat.AppImage"
tar-ignore = "I2PChat*.AppImage"
tar-ignore = "appimagetool*.AppImage"
tar-ignore = "build"
tar-ignore = "debian-ci-out"
tar-ignore = "dist"
tar-ignore = "htmlcov"
tar-ignore = "python"
tar-ignore = "vendor"
