# Example file: ~/.config/i2pchat-blindbox/daemon.env
# Canonical package entrypoint:
#   python3 -m i2pchat.blindbox.daemon

# Public I2P replicas may keep replica auth empty.
BLINDBOX_AUTH_TOKEN=

# Optional separate secret for STATUS / STATUS_JSON / METRICS and localhost HTTP monitoring.
BLINDBOX_ADMIN_TOKEN=

BLINDBOX_MAX_TOTAL_BYTES=536870912
BLINDBOX_MAX_FILES=4096
BLINDBOX_MAX_PREFIX_BYTES=33554432
BLINDBOX_MAX_PREFIX_FILES=256
BLINDBOX_TTL_SEC=1209600
BLINDBOX_RATE_LIMIT_PUTS_PER_MINUTE=240
BLINDBOX_RATE_LIMIT_BYTES_PER_MINUTE=67108864
BLINDBOX_AUDIT_LOG_MAX_BYTES=1048576
BLINDBOX_AUDIT_LOG_BACKUPS=3

# Optional localhost HTTP monitoring
BLINDBOX_HTTP_STATUS=0
BLINDBOX_HTTP_HOST=127.0.0.1
BLINDBOX_HTTP_PORT=19445

# Optional metrics exports
BLINDBOX_METRICS_JSON_PATH=
BLINDBOX_METRICS_PROM_PATH=
