[i2pchat-blindbox]
enabled = true
filter = i2pchat-blindbox
backend = auto
logpath = /home/YOUR_LINUX_USER/.i2pchat-blindbox/audit.log
maxretry = 6
findtime = 10m
bantime = 1h
port = 19444,19445
action = %(action_)s

# Notes:
# - Copy the matching filter into filter.d/i2pchat-blindbox.conf.
# - Port 19445 is the optional localhost HTTP monitoring endpoint.
